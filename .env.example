# codero — environment variable reference
# Copy to .env and customize for your environment.
# Never commit .env with real secrets to source control.

# =============================================================================
# Pre-commit Gate Heartbeat — Timeout Controls
#
# Each gate has its own independent timeout. Setting one does not affect
# the others. The overall total is enforced by the shell gate script.
# =============================================================================

# Timeout for the Copilot review gate (seconds).
# The Copilot gate runs first. Infra/auth failures are non-blocking.
# Default: 15
CODERO_COPILOT_TIMEOUT_SEC=15

# Timeout for the LiteLLM review gate (seconds).
# The LiteLLM gate runs after Copilot, with its own full budget.
# Default: 45
CODERO_LITELLM_TIMEOUT_SEC=45

# Overall wall-clock budget for the gate run (seconds).
# The shell gate enforces this as the outer limit across both gates.
# Default: 180
CODERO_GATE_TOTAL_TIMEOUT_SEC=180

# Interval between gate-heartbeat poll calls (seconds).
# The agent polls this often while the gate is in STATUS: PENDING.
# Default: 180
CODERO_GATE_POLL_INTERVAL_SEC=180

# Path to the shared gate-heartbeat binary.
# Override only if the shared toolkit is mounted at a non-standard path.
# Default: /srv/storage/shared/agent-toolkit/bin/gate-heartbeat
# CODERO_GATE_HEARTBEAT_BIN=/srv/storage/shared/agent-toolkit/bin/gate-heartbeat

# =============================================================================
# Repository Path
# =============================================================================

# Absolute path to the codero repository root.
# Used by gate-heartbeat to locate .codero/gate-heartbeat/progress.env.
# Defaults to the current working directory when not set.
# CODERO_REPO_PATH=/srv/storage/repo/codero

# =============================================================================
# Daemon Configuration
# =============================================================================

# GitHub personal access token (required for daemon mode).
# Required scopes: repo, read:org
# GITHUB_TOKEN=<your-token>

# Comma-separated list of repositories to manage (owner/repo format).
# CODERO_REPOS=myorg/myrepo,myorg/anotherrepo

# Redis connection address.
# Default: localhost:6379
# REDIS_ADDR=localhost:6379

# Redis password (leave empty for no authentication).
# REDIS_PASSWORD=

# SQLite state store path.
# Default: /var/lib/codero/codero.db
# CODERO_DB_PATH=/var/lib/codero/codero.db

# PID file path (for daemon lifecycle management).
# Default: /var/run/codero/codero.pid
# CODERO_PID_FILE=/var/run/codero/codero.pid

# Log level: debug, info, warn, error.
# Default: info
# CODERO_LOG_LEVEL=info

# Log file path (empty = stderr).
# CODERO_LOG_PATH=/var/log/codero/codero.log

# Observability server port.
# Exposes /health, /queue, /metrics, /ready, /gate endpoints.
# Default: 8080
# CODERO_OBSERVABILITY_PORT=8080
