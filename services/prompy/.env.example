# prompy environment configuration
# Copy to .env and fill in values. Never commit .env.

# --- Redis connection ---
# Must match your codero daemon Redis configuration.
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# --- Codero HTTP endpoints (optional) ---
# If codero exposes /health, /queue, /metrics, set this to the base URL.
# Leave blank to use Redis-only mode.
CODERO_BASE_URL=

# --- prompy server ---
PROMPY_PORT=9210
PROMPY_ADDR=0.0.0.0

# --- Tuning ---
# How often to poll (seconds). Default: 15
PROMPY_POLL_INTERVAL_SECONDS=15

# How long a non-empty queue with no lease activity is considered stalled (seconds). Default: 600
PROMPY_STALL_THRESHOLD_SECONDS=600

# HTTP request timeout for codero endpoints (seconds). Default: 5
PROMPY_HTTP_TIMEOUT_SECONDS=5

# Max retries on transient HTTP errors. Default: 3
PROMPY_MAX_RETRIES=3

# --- Docker network (used by docker-compose.yml) ---
DOCKER_NETWORK=codero-net
