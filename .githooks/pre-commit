#!/usr/bin/env bash
set -euo pipefail

# Portable hook wrapper — delegates to shared agent-toolkit when present.
# This file is a regular executable in the repo so CI can verify it exists.
SHARED_HOOK="/srv/storage/shared/agent-toolkit/hooks/pre-commit"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOCAL_GATE="$REPO_ROOT/scripts/review/two-pass-review.sh"

if [ -x "$SHARED_HOOK" ]; then
  exec "$SHARED_HOOK" "$@"
fi

if [ -x "$LOCAL_GATE" ]; then
  exec "$LOCAL_GATE" "$@"
fi

echo "pre-commit: no executable hook backend found" >&2
exit 1
