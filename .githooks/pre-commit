#!/usr/bin/env bash
set -euo pipefail

# Portable hook wrapper for local and CI environments.
# Prefer shared agent-toolkit hook when present; fallback to repo-local gate.
SHARED_HOOK="/srv/storage/shared/agent-toolkit/hooks/pre-commit"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LOCAL_GATE="$REPO_ROOT/scripts/review/two-pass-review.sh"

if [ -x "$SHARED_HOOK" ]; then
  exec "$SHARED_HOOK" "$@"
fi

if [ -x "$LOCAL_GATE" ]; then
  exec "$LOCAL_GATE" "$@"
fi

echo "pre-commit: no executable hook backend found" >&2
exit 1
